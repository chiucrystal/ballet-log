    { "id": "IF-018", "term": "Glissade devant", "french_translation": "sliding step; front", "category": "linking", "free_enchainement_role": "linking", "introduced_at_grade": "IF", "gender": "both", "description": "Glissade sideways initiated by the front foot, no change of feet." },
    { "id": "IF-019", "term": "Glissade derrière", "french_translation": "sliding step; behind", "category": "linking", "free_enchainement_role": "linking", "introduced_at_grade": "IF", "gender": "both", "description": "Glissade sideways initiated by the back foot, no change of feet." },
    { "id": "IF-020", "term": "Glissade dessus", "french_translation": "sliding step; over", "category": "linking", "free_enchainement_role": "linking", "introduced_at_grade": "IF", "gender": "both", "description": "Glissade sideways initiated by the back foot, with a change of feet." },
