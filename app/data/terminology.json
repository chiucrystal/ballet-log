    { "id": "IF-022", "term": "Petit assemblé devant", "french_translation": "small; gathered step; front", "category": "jump", "free_enchainement_role": "linking", "introduced_at_grade": "IF", "gender": "both", "description": "Small jump sur place, working foot begins sur le cou-de-pied devant." },
    { "id": "IF-023", "term": "Petit assemblé derrière", "french_translation": "small; gathered step; behind", "category": "jump", "free_enchainement_role": "linking", "introduced_at_grade": "IF", "gender": "both", "description": "Small jump sur place, working foot begins sur le cou-de-pied derrière." },
