    { "id": "IF-007", "term": "Sissonne fermée de côté devant", "french_translation": "sissonne; closed; sideways; front", "category": "jump", "free_enchainement_role": "focal", "introduced_at_grade": "IF", "gender": "both", "description": "Sissonne fermée de côté — working leg begins and ends in front." },
    { "id": "IF-008", "term": "Sissonne fermée de côté derrière", "french_translation": "sissonne; closed; sideways; behind", "category": "jump", "free_enchainement_role": "focal", "introduced_at_grade": "IF", "gender": "both", "description": "Sissonne fermée de côté — working leg begins and ends behind." },
    { "id": "IF-009", "term": "Sissonne fermée de côté dessus", "french_translation": "sissonne; closed; sideways; over", "category": "jump", "free_enchainement_role": "focal", "introduced_at_grade": "IF", "gender": "both", "description": "Sissonne fermée de côté — working leg begins behind and ends in front." },
    { "id": "IF-010", "term": "Sissonne fermée de côté dessous", "french_translation": "sissonne; closed; sideways; under", "category": "jump", "free_enchainement_role": "focal", "introduced_at_grade": "IF", "gender": "both", "description": "Sissonne fermée de côté — working leg begins in front and ends behind." },
    { "id": "IF-011", "term": "Pas de bourrée devant", "french_translation": "bourrée step; front", "category": "linking", "free_enchainement_role": "linking", "introduced_at_grade": "IF", "gender": "both", "description": "Pas de bourrée travelling sideways, closing actions devant-derrière." },
    { "id": "IF-012", "term": "Pas de bourrée derrière", "french_translation": "bourrée step; behind", "category": "linking", "free_enchainement_role": "linking", "introduced_at_grade": "IF", "gender": "both", "description": "Pas de bourrée travelling sideways, closing actions derrière-devant." },
    { "id": "IF-013", "term": "Pas de bourrée dessus", "french_translation": "bourrée step; over", "category": "linking", "free_enchainement_role": "linking", "introduced_at_grade": "IF", "gender": "both", "description": "Pas de bourrée travelling sideways, closing devant-derrière, finishing derrière." },
    { "id": "IF-014", "term": "Pas de bourrée dessous", "french_translation": "bourrée step; under", "category": "linking", "free_enchainement_role": "linking", "introduced_at_grade": "IF", "gender": "both", "description": "Pas de bourrée travelling sideways, closing derrière-devant, finishing devant." },
    { "id": "IF-015", "term": "Changement", "french_translation": "to change; changing", "category": "jump", "free_enchainement_role": "linking", "introduced_at_grade": "IF", "gender": "both", "description": "A jump from 5th landing in opposite 5th with a change of feet." },
    { "id": "IF-016", "term": "Changement battu", "french_translation": "changing; beaten", "category": "jump", "free_enchainement_role": "linking", "introduced_at_grade": "IF", "gender": "both", "description": "A changement in which the legs beat together in the air before landing with a change of feet." },
