  "terms": [
    { "id": "IF-001", "term": "Assemblé devant", "french_translation": "gathered step; front", "category": "jump", "free_enchainement_role": "focal", "introduced_at_grade": "IF", "gender": "both", "description": "A jump in which the back foot slides out to 2nd and finishes devant." },
    { "id": "IF-002", "term": "Assemblé derrière", "french_translation": "gathered step; behind", "category": "jump", "free_enchainement_role": "focal", "introduced_at_grade": "IF", "gender": "both", "description": "A jump in which the front foot slides out to 2nd and finishes derrière." },
    { "id": "IF-003", "term": "Assemblé dessus", "french_translation": "gathered step; over", "category": "jump", "free_enchainement_role": "focal", "introduced_at_grade": "IF", "gender": "both", "description": "A jump in which the back foot slides out to 2nd and finishes devant (over)." },
    { "id": "IF-004", "term": "Assemblé dessous", "french_translation": "gathered step; under", "category": "jump", "free_enchainement_role": "focal", "introduced_at_grade": "IF", "gender": "both", "description": "A jump in which the front foot slides out to 2nd and finishes derrière (under)." },
    { "id": "IF-005", "term": "Jeté ordinaire devant", "french_translation": "thrown; ordinary; front", "category": "jump", "free_enchainement_role": "focal", "introduced_at_grade": "IF", "gender": "both", "description": "A jump from one foot to the other, freed foot contacts base of shin on landing." },
